{
    "name": "TeX Live base",
    "dockerFile": "Dockerfile",
    "customizations": {
        "vscode": {
            "extensions": [
                "james-yu.latex-workshop"
            ],
            "settings": {
                "latex-workshop.latex.autoBuild.run": "onFileChange",
                "latex-workshop.latex.outDir": "./out",
                "latex-workshop.latex.autoClean.run": "onBuilt"
            }
        }
    }
}